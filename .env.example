# ============================================================
# ECO TRAY SOLUTIONS — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub (it's in .gitignore).
# ============================================================

# Server port (default: 3000)
PORT=3000

# ── SMTP Email Settings ──────────────────────────────────────
# For Gmail: use an App Password (not your main password).
# Google Account → Security → 2-Step Verification → App Passwords
#
# For other providers (Outlook, Mailgun, SendGrid, etc.):
# Update SMTP_HOST and SMTP_PORT accordingly.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# ── Admin Notification Email(s) ──────────────────────────────
# Comma-separated list of emails that receive form submissions
ADMIN_EMAILS=admin@ecotraysolutions.com,you@youremail.com

# ── Sender Identity ──────────────────────────────────────────
FROM_NAME=Eco Tray Solutions Website
FROM_EMAIL=noreply@ecotraysolutions.com
